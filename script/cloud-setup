#!/bin/bash
set -euo pipefail
IFS=$'\n\t'
set -o xtrace

until gcloud compute ssh treewrap --zone=us-west3-a --command 'pwd' ; do
  echo "Instance not fully available, retrying in 5 seconds..."
  sleep 5
done
gcloud compute ssh treewrap --zone=us-west3-a --command 'sudo apt-get install git -y'
gcloud compute ssh treewrap --zone=us-west3-a --command 'wget -q https://go.dev/dl/go1.26.4.linux-amd64.tar.gz'
gcloud compute ssh treewrap --zone=us-west3-a --command 'tar -xzf *.tar.gz'
gcloud compute ssh treewrap --zone=us-west3-a --command "echo 'export PATH=\"\$PATH:~/go/bin\"' >> ~/.bashrc"
gcloud compute ssh treewrap --zone=us-west3-a --command "echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.bashrc"
gcloud compute ssh treewrap --zone=us-west3-a --command 'git clone https://github.com/codahale/treewrap'
# shellcheck disable=SC2016
gcloud compute ssh treewrap --zone=us-west3-a --command 'PATH=$PATH:~/go/bin go install golang.org/x/perf/cmd/benchstat@latest'
